# =============================================================
#  Appearance  (unchanged — your current look)
# =============================================================
# Theme candidates you've been trying:
#   LiquidCarbonTransparent / MaterialDarker / wilmersdorf
#   0x96f pero verde / Aardvark Blue / AlienBlood / Arthur
#   Ayu Mirage / Builtin Solarized Dark / Floraverse pero verde
#   iTerm2 Solarized Dark / RetroLegends / VioletDark / WarmNeon
theme = Floraverse

foreground = 22ff22
background = 2e3436

font-family = "JetBrains Mono"
# font-family = "VT323"
# font-family = "Press Start 2P"
font-size = 12
# adjust-cell-height = 20%

gtk-tabs-location = bottom
# remove the native GNOME title/header bar
gtk-titlebar = false
# window-decoration = false
# adw-toolbar-style = raised-border


# =============================================================
#  Behavior & quality-of-life
# =============================================================

# Keep a big scrollback buffer (bytes). ~100 MB.
scrollback-limit = 100000000

# Shell integration: detects shell, enables jump-to-prompt,
# command-aware selection, working-dir inheritance, etc.
shell-integration = detect
shell-integration-features = cursor,sudo,title

# New splits/tabs/windows open in the current pane's directory.
window-inherit-working-directory = true
window-inherit-font-size = true

# Selecting text copies it straight to the clipboard.
copy-on-select = clipboard

# Let programs read/write the clipboard (e.g. tmux, vim yank).
clipboard-read = allow
clipboard-write = allow
# Trim trailing whitespace and warn on multi-line paste.
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true

# Hide the mouse pointer while you type; show it on move.
mouse-hide-while-typing = true

# Ask before closing a surface only if a process is still running.
confirm-close-surface = true

# Don't quit the whole app when the last window closes (GTK).
quit-after-last-window-closed = false


# =============================================================
#  Keybindings
# =============================================================

# --- your existing binds ---
keybind = ctrl+z=close_surface
keybind = shift+right=next_tab
keybind = shift+left=previous_tab

# --- splits ---
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+w=close_surface

# move focus between splits
keybind = ctrl+alt+left=goto_split:left
keybind = ctrl+alt+right=goto_split:right
keybind = ctrl+alt+up=goto_split:up
keybind = ctrl+alt+down=goto_split:down

# resize the focused split
keybind = ctrl+alt+shift+left=resize_split:left,20
keybind = ctrl+alt+shift+right=resize_split:right,20
keybind = ctrl+alt+shift+up=resize_split:up,20
keybind = ctrl+alt+shift+down=resize_split:down,20

# temporarily maximize / restore the focused split
keybind = ctrl+shift+enter=toggle_split_zoom

# --- tabs ---
keybind = ctrl+shift+n=new_tab
keybind = ctrl+shift+t=new_window

# rename the current tab; a manually-set title is pinned and won't
# be overwritten by the shell/program afterwards
keybind = ctrl+shift+s=prompt_tab_title

# open the tab overview grid (replaces the title bar's tab button)
keybind = alt+backslash=toggle_tab_overview

# jump straight to a tab by number (alt+9 jumps to the last tab)
keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=last_tab

# move the current tab left / right in the tab bar
keybind = ctrl+shift+left=move_tab:-1
keybind = ctrl+shift+right=move_tab:1

# --- font size ---
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# --- misc ---
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+comma=reload_config
